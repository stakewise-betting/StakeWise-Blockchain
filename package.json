{
  "name": "truffle-deploy",
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@truffle/hdwallet-provider": "^2.1.15",
    "web3": "^4.16.0",
    "truffle": "^5.11.5"
